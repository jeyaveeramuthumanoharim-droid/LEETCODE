class Solution(object):
    def climbStairs(self, n):
        """
        :type n: int
        :rtype: int
        """
        if n <= 2:
            return n
        first, second = 1, 2
        for i in range(3, n + 1):
            # The current step is the sum of the previous two
            current = first + second
            # Shift the variables forward for the next step
            first = second
            second = current        
        return second






