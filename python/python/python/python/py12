class Solution:
    def lengthOfLastWord(self, s):
        # s.rstrip() removes trailing spaces; split() returns words
        return len(s.rstrip().split()[-1])

class Solution:
    def lengthOfLastWord(self, s):
        i = len(s) - 1
        while i >= 0 and s[i] == ' ':
            i -= 1
        length = 0
        while i >= 0 and s[i] != ' ':
            length += 1
            i -= 1
        return length
