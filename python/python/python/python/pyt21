class Solution:
    def permute(self, nums):
        """
        Returns all possible permutations of an array of distinct integers.
        Uses a backtracking approach compatible with Python 2.7 and Python 3.x.
        """
        result = []
        
        def backtrack(start):
            # Base case: if we've reached the end of the array, we found a permutation
            if start == len(nums):
                result.append(list(nums))
                return
            
            for i in range(start, len(nums)):
                # Swap the current element with the element at the 'start' position
                nums[start], nums[i] = nums[i], nums[start]
                
                backtrack(start + 1)
                
                nums[start], nums[i] = nums[i], nums[start]
        
        backtrack(0)
        return result

if __name__ == "__main__":
    sol = Solution()
    
    print("Input: [1,2,3]")
    print("Output:", sol.permute([1,2,3]))
    
    print("\nInput: [0,1]")
    print("Output:", sol.permute([0,1]))
