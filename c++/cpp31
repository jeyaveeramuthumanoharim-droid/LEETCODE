#include <cstdio>    
#include <cmath>     
#include <cstdlib>  

void update(int *a, int *b) {
    int temp_a = *a; 
    int temp_b = *b; 

    *a = temp_a + temp_b; 
    *b = std::abs(temp_a - temp_b); 
}

int main() {
    int a, b;
    
    scanf("%d\n%d", &a, &b);

    update(&a, &b); 

  
    printf("%d\n%d", a, b);

    return 0;
}
