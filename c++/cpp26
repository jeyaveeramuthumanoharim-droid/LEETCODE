#include <iostream> 
#include <set>      

int main() {
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int q; 
    std::cin >> q;

    std::set<int> s; 

    for (int i = 0; i < q; ++i) {
        int type, val;
        std::cin >> type >> val;

        if (type == 1) {
            s.insert(val);
        } else if (type == 2) {
            s.erase(val);
        } else if (type == 3) {
            if (s.find(val) != s.end()) {
                std::cout << "Yes\n";
            } else {
                std::cout << "No\n";
            }
        }
    }

    return 0;
}
