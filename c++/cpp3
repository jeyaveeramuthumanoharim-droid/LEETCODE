#include<iostream>
using namespace std;
class digitextractor
{
   private:
      int* digits;
      int size;
   public:
      digitextractor(int number)
      {
            if (number==0)
            {
               digits=new int[1];
               digits[0]=0;
               size=1;
               return;
            }
         int temp =number;
         size=0;
          while (temp > 0)
          {
               size++;
               temp /= 10;
          }
         digits=new int[size];
         for(int i=size-1;i>=0;i--)
         {
            digits[i]=number %10;
            number /=10;
         }
      }
      void display()
         const
         {
            cout<<"number of digits:"<<size<<endl;
            cout<<"digits:";
            for(int i=0;i<size;i++)
            {
               cout<<digits[i]<<" ";
            }
            cout<<endl;
         }
      ~ digitextractor()
      {
         delete[] digits;
      }
};
int main()
{
   int number;
   cout<< "enter an integer:";
   cin>> number;
   digitextractor de(number);
   de.display();
   return 0;
}
