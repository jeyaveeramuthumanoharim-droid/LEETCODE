#include <iostream> 
#include <vector>   
#include <algorithm> 

int main() {
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);

    int N;
    std::cin >> N;

    std::vector<int> v;

    for (int i = 0; i < N; ++i) {
        int x;
        std::cin >> x;
        v.push_back(x);
    }

    std::sort(v.begin(), v.end());

    for (int i = 0; i < N; ++i) {
        std::cout << v[i] << " ";
    }
    std::cout << std::endl; 

    return 0;
}
